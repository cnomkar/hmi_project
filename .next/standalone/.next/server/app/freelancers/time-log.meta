{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/freelancers/layout,_N_T_/freelancers/time-log/layout,_N_T_/freelancers/time-log/page,_N_T_/freelancers/time-log"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/freelancers/time-log/__PAGE__",
    "/freelancers/time-log",
    "/freelancers",
    "/_index",
    "/_head"
  ]
}